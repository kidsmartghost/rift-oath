  "scenes": [
    {
      "id": "scene_001",
      "worldId": "world1",
      "title": "破碎的黎明",
      "type": "narration",
      "speaker": "",
      "dialogue": "黑暗。\n无尽的黑暗。\n\n我睁开双眼，却什么也看不见。\n只有冰冷的石地板贴着脸颊，还有...血腥味。",
      "background": "church",
      "characters": [],
      "bgm": "world1",
      "nextSceneId": "scene_002",
      "effects": {
        "hiddenStats": {
          "chaos": 5
        }
      }
    },
    {
      "id": "scene_002",
      "worldId": "world1",
      "type": "dialogue",
      "speaker": "神秘老人",
      "dialogue": "「你醒了。」\n\n一个苍老的声音在黑暗中响起。",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "nextSceneId": "scene_003"
    },
    {
      "id": "scene_003",
      "worldId": "world1",
      "type": "narration",
      "speaker": "",
      "dialogue": "这是一座破败的教堂。\n彩色玻璃早已破碎，月光从空洞的窗框中洒入。\n\n在我面前，站着一位佝偻的老人，手中握着一盏摇曳的油灯。",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "nextSceneId": "scene_004",
      "dialogueVariants": [
        {
          "conditions": {
            "stats": {
              "wisdom": {
                "min": 60
              }
            }
          },
          "text": "这是一座破败的教堂。\n但...不对劲。\n\n我仔细观察周围的环境——破损的彩窗图案、祭坛的摆放位置、甚至空气中残留的魔法波动。\n\n这不是普通的教堂。这是一个...封印之地？\n\n在我面前，站着一位佝偻的老人，手中握着一盏摇曳的油灯。"
        }
      ],
      "extraLines": {
        "wisdom": "你的直觉告诉你，这座教堂隐藏着秘密。",
        "courage": "你握紧拳头，准备应对任何危险。"
      }
    },
    {
      "id": "scene_004",
      "worldId": "world1",
      "type": "dialogue",
      "speaker": "艾莉娅",
      "dialogue": "「这里是...哪里？我是谁？」\n\n我抚摸着疼痛的太阳穴，脑海中一片空白。",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "nextSceneId": "scene_005"
    },
    {
      "id": "scene_005",
      "worldId": "world1",
      "type": "dialogue",
      "speaker": "神秘老人",
      "dialogue": "老人叹了口气。\n\n「这里是圣罗兰教堂，王都最后的避难所。而你，艾莉娅，是王国最后的圣骑士。」",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "choices": [
        {
          "id": "choice_001_a",
          "text": "「圣骑士...我不明白。」",
          "nextSceneId": "scene_006_a",
          "effects": {
            "stats": {
              "wisdom": 5
            },
            "bonds": {
              "world1": 3
            }
          }
        },
        {
          "id": "choice_001_b",
          "text": "「王国发生了什么？」",
          "nextSceneId": "scene_006_b",
          "effects": {
            "stats": {
              "wisdom": 3,
              "courage": 3
            },
            "bonds": {
              "world1": 5
            }
          }
        },
        {
          "id": "choice_001_c",
          "text": "「你认识我？」",
          "nextSceneId": "scene_006_c",
          "effects": {
            "stats": {
              "compassion": 5
            },
            "bonds": {
              "world1": 4
            }
          }
        },
        {
          "id": "choice_001_d",
          "text": "「证明给我看。」",
          "nextSceneId": "scene_006_d",
          "conditions": {
            "stats": {
              "wisdom": {
                "min": 40
              }
            }
          },
          "fallbackSceneId": null,
          "effects": {
            "stats": {
              "wisdom": 8,
              "determination": 5
            }
          }
        }
      ]
    },
    {
      "id": "scene_006_a",
      "worldId": "world1",
      "type": "dialogue",
      "speaker": "神秘老人",
      "dialogue": "「你的剑会告诉你答案。」\n\n老人指向一旁。那里插着一把古老的长剑，剑身上刻满了金色的符文。",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "nextSceneId": "scene_007"
    },
    {
      "id": "scene_006_b",
      "worldId": "world1",
      "type": "dialogue",
      "speaker": "神秘老人",
      "dialogue": "「三个月前，国王陛下与黑暗签订了契约。从那天起，太阳再也没有升起。」\n\n「王国...已经死了。」",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "nextSceneId": "scene_007",
      "effects": {
        "hiddenStats": {
          "corruption": 3
        }
      }
    },
    {
      "id": "scene_006_c",
      "worldId": "world1",
      "type": "dialogue",
      "speaker": "神秘老人",
      "dialogue": "「我侍奉王室三代，孩子。」\n\n「看着你从一个小女孩成长为圣骑士...也看着你在最后一战中倒下。」",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "nextSceneId": "scene_007",
      "effects": {
        "bonds": {
          "world1": 5
        }
      }
    },
    {
      "id": "scene_006_d",
      "worldId": "world1",
      "type": "dialogue",
      "speaker": "神秘老人",
      "dialogue": "老人眼中闪过一丝惊讶。\n\n「聪明的孩子。没错，我需要证明。」\n\n他伸出手，掌心浮现出一枚徽章——王室的纹章，还有一滴干涸的血迹。\n\n「这是你父亲，老国王临终前交给我的。」",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "nextSceneId": "scene_007",
      "effects": {
        "stats": {
          "wisdom": 5
        },
        "bonds": {
          "world1": 8
        }
      }
    },
    {
      "id": "scene_007",
      "worldId": "world1",
      "type": "narration",
      "speaker": "",
      "dialogue": "突然，教堂外传来一声巨响。\n\n老人脸色大变：「它们找到这里了！快，拿起你的剑！」",
      "background": "church",
      "characters": [
        "oldman"
      ],
      "bgm": "battle",
      "nextSceneId": "scene_008"
    },
    {
      "id": "scene_008",
      "worldId": "world1",
      "type": "narration",
      "speaker": "",
      "dialogue": "我冲向那把剑。就在手指触碰到剑柄的瞬间——\n\n剧痛。\n\n无数画面涌入脑海：燃烧的城堡、嘶吼的怪物、还有一道...撕裂天空的紫色裂隙？",
      "background": "church",
      "characters": [],
      "nextSceneId": "scene_009",
      "effects": {
        "hiddenStats": {
          "chaos": 5
        }
      }
