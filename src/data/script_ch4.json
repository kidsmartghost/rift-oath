    {
      "id": "scene_110_world4_glow",
      "worldId": "world4",
      "type": "narration",
      "speaker": "",
      "dialogue": "光芒越来越强。\n\n你鬼使神差地走了进去。\n\n图书馆内部...完全变了。\n\n书架上摆放的不是书，而是...水晶？",
      "background": "library",
      "characters": [],
      "nextSceneId": "scene_111_world4_crystal"
    },
    {
      "id": "scene_110_world4_book",
      "worldId": "world4",
      "type": "dialogue",
      "speaker": "图书管理员",
      "dialogue": "「你对这本书感兴趣？」\n\n一个苍老的声音从身后传来。\n\n你转过身，看到一个穿着白袍的老人。他的眼睛...是紫色的。",
      "background": "library",
      "characters": [
        "observer"
