      "nextSceneId": "scene_111_world4_meet"
    },
    {
      "id": "scene_111_world4_dream",
      "worldId": "world4",
      "type": "narration",
      "speaker": "",
      "dialogue": "你睡着了。\n\n再次梦到了那个画面。\n\n紫色的裂隙，还有...一个声音在呼唤你。",
      "background": "classroom",
      "characters": [],
