    {
      "id": "scene_107_world4",
      "worldId": "world4",
      "type": "dialogue",
      "speaker": "同桌",
      "dialogue": "「你睡了一整节课！」同桌推了推我，「老班刚才瞪了你三次。」\n\n我揉了揉眼睛。\n\n刚才那是...梦？\n\n圣骑士、机器人、半神...都是梦？",
      "background": "classroom",
      "characters": [],
      "nextSceneId": "scene_108_world4"
    },
