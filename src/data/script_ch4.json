            "stats": {
              "wisdom": 10
            }
          }
        },
        {
          "id": "choice_041_b",
          "text": "【忽略】强迫自己睡觉",
          "nextSceneId": "scene_111_world4_sleep",
          "effects": {
            "stats": {
              "determination": 5
            }
          }
        },
        {
          "id": "choice_041_c",
          "text": "【搜索】上网查相关信息",
