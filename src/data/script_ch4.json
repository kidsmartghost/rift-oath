    {
      "id": "scene_111_world4_diary",
      "worldId": "world4",
      "type": "narration",
      "speaker": "",
      "dialogue": "你打开日记本，开始记录。\n\n「我梦到了...一个圣骑士，一个机器人，一个半神...」\n\n写着写着，你发现...这些记忆太真实了。",
      "background": "classroom",
      "characters": [],
      "nextSceneId": "scene_112_world4_realize"
